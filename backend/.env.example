# Database
DATABASE_URL=sqlite:///./trivex.db

# JWT Secret
JWT_SECRET=trivex-super-secret-jwt-key-change-in-production

# Cloudinary — format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# You can find these at https://console.cloudinary.com/settings/api-keys
CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# Admin seeding
ADMIN_EMAIL=admin@trivex.io
ADMIN_PASSWORD=changeme123